{% extends "base.html" %}
{% block title %} Recommendation Cluster {% endblock %}

{% block content %}

<h1>Original text</h1>

<p>
{{text}}
</p>

<h1>Recommendation</h1>
{% for i in range(candidateClusters|length) %}
    <p><b>Cluster {{i}}:</b></p>
    {% for candidate in candidateClusters[i]%}
        <p>{{ candidate }}</p>
    {% endfor %}
{% endfor %}

<a href="{{ url_for('demo') }}">Return</a>

{% endblock %}
